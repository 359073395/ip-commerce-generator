{
  "name": "ip-commerce-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "node server/index.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "verify:knowledge": "node --input-type=module -e \"import('./server/knowledge/loadKnowledge.mjs').then(async ({ verifyKnowledgeFiles }) => { const result = await verifyKnowledgeFiles(); console.log(JSON.stringify(result, null, 2)); process.exit(result.ok ? 0 : 1); })\"",
    "check": "npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  }
}
