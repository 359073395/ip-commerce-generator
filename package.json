{
  "name": "ip-commerce-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "node server/index.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "verify:knowledge": "node --input-type=module -e \"import('./server/knowledge/loadKnowledge.mjs').then(async ({ verifyKnowledgeFiles }) => { const result = await verifyKnowledgeFiles(); console.log(JSON.stringify(result, null, 2)); process.exit(result.ok ? 0 : 1); })\"",
    "test:agent-contract": "node tools/run-agent-contract-test.mjs",
    "test:agent-planner-dirty": "node tools/run-agent-planner-dirty-test.mjs",
    "test:project-profile": "node tools/run-project-profile-test.mjs",
    "test:auth-projects": "node tools/run-auth-project-test.mjs",
    "test:admin-overview": "node tools/run-admin-overview-test.mjs",
    "test:generation-history": "node tools/run-generation-history-test.mjs",
    "test:agent-execution": "node tools/run-agent-execution-test.mjs",
    "test:knowledge-retrieval": "node tools/run-knowledge-retrieval-test.mjs",
    "test:quality-evaluation": "node tools/run-quality-evaluation-test.mjs",
    "test:productized-generation": "node tools/run-productized-generation-test.mjs",
    "test:quality-benchmark": "node tools/run-quality-benchmark-test.mjs",
    "benchmark:models": "node tools/run-model-quality-benchmark.mjs",
    "check": "npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1",
    "vite": "^6.0.5"
  }
}
